source "https://rubygems.org"

# Keep the content validation workflow independent of the large github-pages
# dependency bundle so PR checks remain stable on current GitHub runners.
gem "jekyll", "~> 4.3"
gem "minima", "~> 2.5"

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"
  gem "jekyll-seo-tag", "~> 2.8"
  gem "jekyll-sitemap", "~> 1.4"
  gem "jekyll-paginate", "~> 1.1"
end
